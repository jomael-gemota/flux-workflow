PORT=
MONGODB_URI=
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

# ── Email Notifications (SMTP Service Account) ────────────────────────────────
# Used to send automated failure/partial-failure alerts for workflow executions.
# All four fields (SMTP_HOST, SMTP_USER, SMTP_PASS, SMTP_FROM_ADDRESS) must be
# set for notifications to be sent.  Notifications are still disabled by default
# until explicitly turned on inside the platform's Notification settings.
#
# Example — Gmail (App Password required; 2-Step Verification must be enabled):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=alerts@your-domain.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM_ADDRESS=alerts@your-domain.com
#
# Example — Outlook / Microsoft 365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=alerts@your-org.com
#   SMTP_PASS=your-password
#   SMTP_FROM_ADDRESS=alerts@your-org.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Flux Workflow
SMTP_FROM_ADDRESS=

# Base URL of this platform instance — used in notification email links
APP_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWTs — change this to a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (same app used for both user login and Google Workspace integrations)
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web Application)
# 3. Add these Authorised redirect URIs:
#      http://localhost:3000/api/auth/google/callback   ← user login
#      http://localhost:3000/api/oauth/google/callback  ← workspace integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Google Workspace OAuth 2.0
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Gmail, Drive, Docs, Sheets APIs
# 3. Create OAuth 2.0 credentials (Web Application type)
# 4. Add the redirect URI below to your Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Slack OAuth 2.0
# 1. Create a Slack app at https://api.slack.com/apps
# 2. Add OAuth scopes: chat:write, im:write, files:write, conversations:history, channels:read, users:read
# 3. Add the redirect URI below to your Slack app settings
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/oauth/slack/callback

# Microsoft Teams OAuth 2.0 (via Microsoft Graph)
# 1. Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# 2. Add the redirect URI below under Authentication → Web → Redirect URIs
# 3. Grant API permissions: Team.ReadBasic.All, Channel.ReadBasic.All, ChannelMessage.Send,
#    ChannelMessage.Read.All, Chat.ReadWrite, User.ReadBasic.All (Delegated)
# 4. Create a client secret under Certificates & secrets
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=common
TEAMS_REDIRECT_URI=http://localhost:3000/api/oauth/teams/callback

# Basecamp 3 OAuth 2.0
# 1. Register your integration at https://launchpad.37signals.com/integrations
# 2. Add the redirect URI below to your integration settings
# 3. Tokens expire every 2 weeks and are auto-refreshed
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_REDIRECT_URI=http://localhost:3000/api/oauth/basecamp/callback